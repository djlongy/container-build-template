# ─── TEMPLATE — copy to image.env, then edit your copy ─────────────
#   cp Dockerfile.example Dockerfile
#   cp image.env.example  image.env  &&  $EDITOR image.env
#
# This is the SLIM starter: the required knob + the common push
# backends. EVERYTHING else — upstream-mirror auth, per-segment
# overrides, all 5 SBOM sinks + 3 vuln sinks, Xray/Trivy/Grype tuning,
# cert injection, air-gap mirror URLs, tag-suffix toggles — is in
# image.env.reference. Copy lines across from there as you need them.
#
# image.env is NEVER committed. Keep SECRETS out of it — pass tokens as
# masked CI variables. Precedence: shell / CI vars > image.env.
# ───────────────────────────────────────────────────────────────────

# ── Upstream base image (REQUIRED) ─────────────────────────────────
# ONE full image URL: registry + repo + :tag. build.sh splits it and
# Renovate auto-bumps the tag from this line. Shorthand also works
# (nginx:1.25.3-alpine → docker.io/library/nginx). A private mirror
# that needs its own pull creds → see "Upstream PULL auth" in reference.
UPSTREAM_REF="docker.io/library/nginx:1.25.3-alpine"

# ── OCI label ───────────────────────────────────────────────────────
VENDOR="example.com"

# ═══════════════════════════════════════════════════════════════════
# PUSH BACKEND — only needed for `build.sh --push`; pick ONE
# ═══════════════════════════════════════════════════════════════════
# REGISTRY_KIND resolves to scripts/push-backends/<value>.sh (default
# "harbor"). Set the matching cred block; keep secrets in CI variables.
#   harbor | artifactory_jcr (Free) | artifactory_pro (Pro)
# REGISTRY_KIND="harbor"

# ── Harbor (REGISTRY_KIND="harbor") ────────────────────────────────
# Push URL = <HARBOR_REGISTRY>/<HARBOR_PROJECT>/<IMAGE_NAME>:<TAG>.
# HARBOR_REGISTRY="harbor.example.com"
# HARBOR_PROJECT="apps/platform"
# HARBOR_USER="svc-cicd"
# HARBOR_PASSWORD="<robot-token>"               # mask in CI

# ── Artifactory (REGISTRY_KIND="artifactory_jcr" | "artifactory_pro") ─
# ARTIFACTORY_USER must be the access-token `sub` user, not the email.
# The repo-path layout (ARTIFACTORY_PUSH_HOST / _PROJECT / _TEAM /
# _REPO_SUFFIX, with six worked presets) lives in image.env.reference.
# ARTIFACTORY_URL="https://artifactory.example.com"   # Cloud: https://<org>.jfrog.io
# ARTIFACTORY_USER="svc-deploy"
# ARTIFACTORY_TOKEN="<access-token>"            # mask in CI (or ARTIFACTORY_PASSWORD)
# ARTIFACTORY_PROJECT="team"

# ───────────────────────────────────────────────────────────────────
# Need cert injection, SBOM/vuln sinks, Xray scanning, air-gap mirrors,
# source SBOMs, USER overrides, the full Artifactory layout presets, …?
#   → image.env.reference  (the complete, annotated option set)
# ───────────────────────────────────────────────────────────────────
